{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@synteq/shared": ["packages/shared/dist/index.d.ts"],
      "@synteq/shared/*": ["packages/shared/dist/*"]
    }
  }
}
