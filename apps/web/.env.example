# Canonical API origin used by web middleware, server routes, and server components.
SYNTEQ_WEB_API_BASE_URL=http://localhost:8080

# Backward-compatible fallbacks. Keep aligned with SYNTEQ_WEB_API_BASE_URL.
API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Set to false for guarded-launch deployments so the signup page shows invite-only posture.
NEXT_PUBLIC_ALLOW_PUBLIC_SIGNUP=false
