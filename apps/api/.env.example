##########################################
# Synteq API local/development defaults
##########################################

NODE_ENV=development
PORT=8080

DATABASE_URL=mysql://root:root@localhost:3306/synteq
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED=false
REDIS_KEY_PREFIX=synteq

BIGQUERY_PROJECT_ID=your-gcp-project
BIGQUERY_DATASET=synteq
BIGQUERY_KEY_JSON=
BIGQUERY_AGG_LOOKBACK_MINUTES=15

PUBSUB_PROJECT_ID=
PUBSUB_TOPIC_INGEST=
PUBSUB_PUSH_SHARED_SECRET=dev-only-pubsub-push-shared-secret-change-before-production

ENABLE_SECRET_MANAGER=false
SYNTEQ_API_KEY_SALT=dev-only-api-key-salt-change-before-production

INGEST_HMAC_SECRET=dev-only-ingest-hmac-secret-change-before-production
INGEST_HMAC_REQUIRED=false
INGEST_SIGNATURE_MAX_SKEW_SEC=300
INGEST_DEDUPE_TTL_SEC=900
INGEST_RATE_LIMIT_PER_MIN=600
MAX_INGEST_BODY_BYTES=262144

SLACK_DEFAULT_WEBHOOK_URL=
JWT_SECRET=dev-only-jwt-secret-change-before-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

BREVO_API_KEY=
EMAIL_DEV_MODE=true

DASHBOARD_ADMIN_EMAIL=admin@synteq.local
DASHBOARD_ADMIN_PASSWORD=DevOnlyChangeMe123!
DEFAULT_TENANT_ID=

CORS_ORIGIN=http://localhost:3000
WEB_BASE_URL=http://localhost:3000

INVITE_RATE_LIMIT_PER_HOUR=20
INVITE_PER_EMAIL_PER_DAY=3
AUTH_LOGIN_MAX_ATTEMPTS_PER_IP=10
AUTH_LOGIN_MAX_ATTEMPTS_PER_EMAIL=5
AUTH_LOGIN_WINDOW_SEC=900
AUTH_LOGIN_LOCKOUT_SEC=900
LOGOUT_ALL_ENABLED=true

METRICS_CACHE_TTL_SEC=45
INCIDENT_ESCALATION_MINUTES=20
INCIDENT_COOLDOWN_WINDOWS=3
ALERT_DISPATCH_MAX_RETRIES=3
ALERT_DISPATCH_BACKOFF_BASE_SEC=30
SYNTEQ_PIPELINE_MAX_DELAY_AGGREGATE_MIN=5
SYNTEQ_PIPELINE_MAX_DELAY_ANOMALY_MIN=7
SYNTEQ_PIPELINE_MAX_DELAY_ALERTS_MIN=7

FX_RATE_USD=1
FX_RATE_PHP=56
FX_RATE_EUR=0.92
FX_RATE_GBP=0.79
FX_RATE_JPY=150
FX_RATE_AUD=1.53
FX_RATE_CAD=1.36

##########################################
# Production contract (must override)
##########################################
# NODE_ENV=production
# REDIS_REQUIRED=true
# INGEST_HMAC_REQUIRED=true
# EMAIL_DEV_MODE=false
# CORS_ORIGIN=https://app.your-domain.com
# PUBSUB_PROJECT_ID=your-gcp-project
# PUBSUB_TOPIC_INGEST=synteq-ingest
# PUBSUB_PUSH_SHARED_SECRET=<strong-random-secret>
# INGEST_HMAC_SECRET=<strong-random-secret>
# JWT_SECRET=<strong-random-secret>
# SYNTEQ_API_KEY_SALT=<strong-random-secret>
# DASHBOARD_ADMIN_PASSWORD=<strong-random-password>
# BREVO_API_KEY=<real-provider-api-key>
