generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  admin
  engineer
  viewer
}

enum IncidentStatus {
  open
  acked
  resolved
}

enum Severity {
  warn
  low
  medium
  high
  critical
}

enum AlertChannelType {
  slack
  webhook
  email
}

enum Comparator {
  gt
  gte
  lt
  lte
  eq
}

enum OperationalFindingStatus {
  open
  resolved
}

enum EventIdempotencyStatus {
  processing
  completed
  failed
}

model Tenant {
  id         String           @id @default(uuid()) @db.VarChar(36)
  name       String           @db.VarChar(191)
  plan       String           @db.VarChar(64)
  trial_status String         @default("none") @db.VarChar(32)
  trial_started_at DateTime?
  trial_ends_at DateTime?
  trial_source String?        @db.VarChar(64)
  timezone   String           @default("UTC") @db.VarChar(64)
  default_currency String     @default("USD") @db.VarChar(3)
  created_at DateTime         @default(now())
  users      User[]
  api_keys   ApiKey[]
  workflows  Workflow[]
  policies   AlertPolicy[]
  channels   AlertChannel[]
  incidents  Incident[]
  invites    Invite[]
  operational_events OperationalEvent[]
  github_integrations GitHubIntegration[]
  operational_findings OperationalFinding[]
  finding_incident_links FindingIncidentLink[]
  event_idempotency_ledger EventIdempotencyLedger[]

  @@map("tenants")
}

model User {
  id                         String                    @id @default(uuid()) @db.VarChar(36)
  tenant_id                  String                    @db.VarChar(36)
  email                      String                    @db.VarChar(191)
  full_name                  String                    @db.VarChar(191)
  password_hash              String                    @default("") @db.VarChar(255)
  role                       UserRole                  @default(viewer)
  email_verified_at          DateTime?
  created_at                 DateTime                  @default(now())
  updated_at                 DateTime                  @updatedAt
  disabled_at                DateTime?
  tenant                     Tenant                    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  refresh_tokens             RefreshToken[]
  email_verification_tokens  EmailVerificationToken[]
  password_reset_tokens      PasswordResetToken[]
  invites_sent               Invite[]                  @relation("InviteSender")

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  token_hash String   @unique @db.VarChar(64)
  expires_at DateTime
  created_at DateTime @default(now())
  revoked_at DateTime?
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, expires_at])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  token_hash String   @unique @db.VarChar(64)
  expires_at DateTime
  created_at DateTime @default(now())
  used_at    DateTime?
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, expires_at])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String   @id @default(uuid()) @db.VarChar(36)
  user_id    String   @db.VarChar(36)
  token_hash String   @unique @db.VarChar(64)
  expires_at DateTime
  created_at DateTime @default(now())
  used_at    DateTime?
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, expires_at])
  @@map("password_reset_tokens")
}

model Invite {
  id                 String   @id @default(uuid()) @db.VarChar(36)
  tenant_id          String   @db.VarChar(36)
  email              String   @db.VarChar(191)
  role               UserRole
  token_hash         String   @unique @db.VarChar(64)
  invited_by_user_id String   @db.VarChar(36)
  expires_at         DateTime
  accepted_at        DateTime?
  created_at         DateTime @default(now())
  tenant             Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invited_by_user    User     @relation("InviteSender", fields: [invited_by_user_id], references: [id], onDelete: Restrict)

  @@index([tenant_id, email, accepted_at])
  @@index([tenant_id, email, created_at])
  @@index([tenant_id, expires_at])
  @@map("invites")
}

model SecurityEvent {
  id            String   @id @default(uuid()) @db.VarChar(36)
  tenant_id     String?  @db.VarChar(36)
  user_id       String?  @db.VarChar(36)
  type          String   @db.VarChar(64)
  ip            String?  @db.VarChar(64)
  user_agent    String?  @db.VarChar(512)
  metadata_json Json
  created_at    DateTime @default(now())

  @@index([tenant_id, created_at])
  @@index([user_id, created_at])
  @@index([type, created_at])
  @@map("security_events")
}

model OperationalEvent {
  id              String    @id @default(uuid()) @db.VarChar(36)
  tenant_id       String    @db.VarChar(36)
  source          String    @db.VarChar(64)
  event_type      String    @db.VarChar(128)
  system          String    @db.VarChar(191)
  service         String?   @db.VarChar(191)
  environment     String?   @db.VarChar(64)
  event_ts        DateTime
  severity        Severity?
  correlation_key String?   @db.VarChar(191)
  metadata_json   Json
  request_id      String?   @db.VarChar(64)
  api_key_id      String?   @db.VarChar(36)
  created_at      DateTime  @default(now())
  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  api_key         ApiKey?   @relation(fields: [api_key_id], references: [id], onDelete: SetNull)
  idempotency_entries EventIdempotencyLedger[]

  @@index([tenant_id, event_ts])
  @@index([tenant_id, source, event_type, event_ts])
  @@index([tenant_id, correlation_key, event_ts])
  @@index([api_key_id, created_at])
  @@index([created_at, id])
  @@map("operational_events")
}

model EventIdempotencyLedger {
  id                 String               @id @default(uuid()) @db.VarChar(36)
  tenant_id          String               @db.VarChar(36)
  source             String               @db.VarChar(64)
  idempotency_key    String               @db.VarChar(128)
  status             EventIdempotencyStatus @default(processing)
  first_seen_at      DateTime             @default(now())
  last_seen_at       DateTime             @default(now())
  completed_at       DateTime?
  lock_expires_at    DateTime?
  error_code         String?              @db.VarChar(64)
  error_message      String?              @db.VarChar(512)
  operational_event_id String?            @db.VarChar(36)
  seen_count         Int                  @default(1)
  attempt_count      Int                  @default(1)
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt
  tenant             Tenant               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  operational_event  OperationalEvent?    @relation(fields: [operational_event_id], references: [id], onDelete: SetNull)

  @@unique([tenant_id, source, idempotency_key], map: "eid_ledger_tenant_source_key_uq")
  @@index([tenant_id, source, status, last_seen_at], map: "eid_ledger_tenant_source_status_seen_idx")
  @@index([status, lock_expires_at], map: "eid_ledger_status_lock_idx")
  @@index([operational_event_id], map: "eid_ledger_op_event_idx")
  @@map("event_idempotency_ledger")
}

model WorkerLease {
  worker_name        String    @id @db.VarChar(128)
  owner_token        String?   @db.VarChar(191)
  lease_expires_at   DateTime?
  acquired_at        DateTime?
  renewed_at         DateTime?
  last_heartbeat_at  DateTime?
  last_completed_at  DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@index([lease_expires_at], map: "worker_lease_expires_idx")
  @@index([owner_token, lease_expires_at], map: "worker_lease_owner_exp_idx")
  @@map("worker_leases")
}

model OperationalEventAnalysisCursor {
  worker_key            String   @id @db.VarChar(64)
  last_event_created_at DateTime?
  last_event_id         String?  @db.VarChar(36)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("operational_event_analysis_cursors")
}

model OperationalFinding {
  id              String                   @id @default(uuid()) @db.VarChar(36)
  tenant_id       String                   @db.VarChar(36)
  source          String                   @db.VarChar(64)
  rule_key        String                   @db.VarChar(128)
  severity        Severity
  status          OperationalFindingStatus @default(open)
  system          String                   @db.VarChar(191)
  correlation_key String?                  @db.VarChar(191)
  fingerprint     String                   @db.VarChar(64)
  summary         String                   @db.VarChar(512)
  evidence_json   Json
  first_seen_at   DateTime
  last_seen_at    DateTime
  resolved_at     DateTime?
  event_count     Int                      @default(1)
  created_at      DateTime                 @default(now())
  updated_at      DateTime                 @updatedAt
  tenant          Tenant                   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  incident_links  FindingIncidentLink[]

  @@unique([tenant_id, fingerprint])
  @@index([tenant_id, status, last_seen_at])
  @@index([tenant_id, source, rule_key, system])
  @@index([tenant_id, correlation_key, status])
  @@map("operational_findings")
}

model IncidentBridgeCursor {
  worker_key              String   @id @db.VarChar(64)
  last_finding_updated_at DateTime?
  last_finding_id         String?  @db.VarChar(36)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@map("incident_bridge_cursors")
}

model FindingIncidentLink {
  id             Int              @id @default(autoincrement())
  tenant_id      String           @db.VarChar(36)
  finding_id     String           @unique @db.VarChar(36)
  incident_id    String           @db.VarChar(36)
  bridge_key     String           @db.VarChar(64)
  last_bridged_at DateTime        @default(now())
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  tenant         Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  finding        OperationalFinding @relation(fields: [finding_id], references: [id], onDelete: Cascade)
  incident       Incident         @relation(fields: [incident_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, bridge_key])
  @@index([incident_id])
  @@index([tenant_id, updated_at])
  @@map("finding_incident_links")
}

model ApiKey {
  id           String    @id @default(uuid()) @db.VarChar(36)
  tenant_id    String    @db.VarChar(36)
  name         String    @db.VarChar(191)
  key_hash     String    @unique @db.VarChar(64)
  last_used_at DateTime?
  revoked_at   DateTime?
  created_at   DateTime  @default(now())
  tenant       Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  operational_events OperationalEvent[]

  @@index([tenant_id])
  @@map("api_keys")
}

model GitHubIntegration {
  id                   String   @id @default(uuid()) @db.VarChar(36)
  tenant_id            String   @db.VarChar(36)
  webhook_id           String   @unique @db.VarChar(64)
  webhook_secret       String   @db.VarChar(255)
  repository_full_name String?  @db.VarChar(255)
  is_active            Boolean  @default(true)
  last_delivery_id     String?  @db.VarChar(128)
  last_seen_at         DateTime?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  tenant               Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, is_active])
  @@index([repository_full_name])
  @@map("github_integrations")
}

model Workflow {
  id            String            @id @default(uuid()) @db.VarChar(36)
  tenant_id     String            @db.VarChar(36)
  slug          String            @db.VarChar(191)
  display_name  String            @db.VarChar(191)
  system        String            @db.VarChar(191)
  environment   String            @db.VarChar(64)
  source_type   String            @default("workflow") @db.VarChar(32)
  is_active     Boolean           @default(true)
  created_at    DateTime          @default(now())
  tenant        Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  versions      WorkflowVersion[]
  policies      AlertPolicy[]
  incidents     Incident[]

  @@unique([tenant_id, slug, environment])
  @@index([tenant_id])
  @@index([tenant_id, source_type, is_active])
  @@map("workflows")
}

model WorkflowVersion {
  id          String   @id @default(uuid()) @db.VarChar(36)
  workflow_id String   @db.VarChar(36)
  version     String   @db.VarChar(128)
  config_json Json
  deployed_at DateTime?
  created_at  DateTime @default(now())
  workflow    Workflow @relation(fields: [workflow_id], references: [id], onDelete: Cascade)

  @@index([workflow_id])
  @@map("workflow_versions")
}

model AlertPolicy {
  id                 String               @id @default(uuid()) @db.VarChar(36)
  tenant_id          String               @db.VarChar(36)
  name               String               @db.VarChar(191)
  metric             String               @db.VarChar(64)
  window_sec         Int                  @default(300)
  threshold          Float
  comparator         Comparator           @default(gte)
  min_events         Int                  @default(20)
  severity           Severity             @default(medium)
  is_enabled         Boolean              @default(true)
  filter_workflow_id String?              @db.VarChar(36)
  filter_env         String?              @db.VarChar(64)
  created_at         DateTime             @default(now())
  tenant             Tenant               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  workflow           Workflow?            @relation(fields: [filter_workflow_id], references: [id], onDelete: SetNull)
  channels           AlertPolicyChannel[]
  incidents          Incident[]

  @@index([tenant_id, is_enabled])
  @@map("alert_policies")
}

model AlertChannel {
  id         String               @id @default(uuid()) @db.VarChar(36)
  tenant_id  String               @db.VarChar(36)
  type       AlertChannelType
  name       String               @db.VarChar(191)
  config_json Json
  is_enabled Boolean              @default(true)
  created_at DateTime             @default(now())
  tenant     Tenant               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  policies   AlertPolicyChannel[]

  @@index([tenant_id, is_enabled])
  @@map("alert_channels")
}

model AlertPolicyChannel {
  policy_id  String       @db.VarChar(36)
  channel_id String       @db.VarChar(36)
  policy     AlertPolicy  @relation(fields: [policy_id], references: [id], onDelete: Cascade)
  channel    AlertChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)

  @@id([policy_id, channel_id])
  @@map("alert_policy_channels")
}

model Incident {
  id          String         @id @default(uuid()) @db.VarChar(36)
  tenant_id   String         @db.VarChar(36)
  policy_id   String?        @db.VarChar(36)
  workflow_id String?        @db.VarChar(36)
  environment String?        @db.VarChar(64)
  status      IncidentStatus @default(open)
  severity    Severity       @default(medium)
  started_at  DateTime
  last_seen_at DateTime
  resolved_at DateTime?
  sla_due_at DateTime
  sla_breached_at DateTime?
  fingerprint String         @db.VarChar(64)
  summary     String         @db.VarChar(512)
  details_json Json
  created_at  DateTime       @default(now())
  tenant      Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  policy      AlertPolicy?   @relation(fields: [policy_id], references: [id], onDelete: SetNull)
  workflow    Workflow?      @relation(fields: [workflow_id], references: [id], onDelete: SetNull)
  events      IncidentEvent[]
  finding_links FindingIncidentLink[]

  @@index([tenant_id, status])
  @@index([tenant_id, status, sla_due_at])
  @@index([policy_id, workflow_id, environment, status])
  @@index([fingerprint])
  @@map("incidents")
}

model IncidentEvent {
  id          Int      @id @default(autoincrement())
  incident_id String   @db.VarChar(36)
  at_time     DateTime @default(now())
  event_type  String   @db.VarChar(64)
  payload_json Json
  incident    Incident @relation(fields: [incident_id], references: [id], onDelete: Cascade)

  @@index([incident_id, at_time])
  @@index([event_type, at_time])
  @@map("incident_events")
}
