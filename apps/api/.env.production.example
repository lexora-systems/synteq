##########################################
# Synteq API production contract template
##########################################

NODE_ENV=production
PORT=8080

DATABASE_URL=mysql://<user>:<password>@<host>:3306/<database>

REDIS_REQUIRED=true
REDIS_URL=redis://<host>:6379
REDIS_KEY_PREFIX=synteq

BIGQUERY_PROJECT_ID=<gcp-project-id>
BIGQUERY_DATASET=synteq
BIGQUERY_KEY_JSON=sm://projects/<project>/secrets/<secret>/versions/latest
BIGQUERY_AGG_LOOKBACK_MINUTES=15

PUBSUB_PROJECT_ID=<gcp-project-id>
PUBSUB_TOPIC_INGEST=<pubsub-topic-name>
PUBSUB_PUSH_SHARED_SECRET=<strong-random-secret-min-32>
SCHEDULER_SHARED_SECRET=<strong-random-secret-min-32>

ENABLE_SECRET_MANAGER=true
SYNTEQ_API_KEY_SALT=<strong-random-secret-min-32>

INGEST_HMAC_REQUIRED=true
INGEST_HMAC_SECRET=<strong-random-secret-min-32>
INGEST_SIGNATURE_MAX_SKEW_SEC=300
INGEST_DEDUPE_TTL_SEC=900
INGEST_RATE_LIMIT_PER_MIN=600
MAX_INGEST_BODY_BYTES=262144

SLACK_DEFAULT_WEBHOOK_URL=<optional-slack-webhook-url>

JWT_SECRET=<strong-random-secret-min-32>
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

EMAIL_DEV_MODE=false
BREVO_API_KEY=<real-provider-api-key>

DASHBOARD_ADMIN_EMAIL=<admin-email>
DASHBOARD_ADMIN_PASSWORD=<strong-random-password-min-14>
DEFAULT_TENANT_ID=
ALLOW_PUBLIC_SIGNUP=true

CORS_ORIGIN=https://app.your-domain.com
WEB_BASE_URL=https://app.your-domain.com

INVITE_RATE_LIMIT_PER_HOUR=20
INVITE_PER_EMAIL_PER_DAY=3
AUTH_LOGIN_MAX_ATTEMPTS_PER_IP=10
AUTH_LOGIN_MAX_ATTEMPTS_PER_EMAIL=5
AUTH_LOGIN_WINDOW_SEC=900
AUTH_LOGIN_LOCKOUT_SEC=900
LOGOUT_ALL_ENABLED=true

METRICS_CACHE_TTL_SEC=45
INCIDENT_ESCALATION_MINUTES=20
INCIDENT_COOLDOWN_WINDOWS=3
ALERT_DISPATCH_MAX_RETRIES=3
ALERT_DISPATCH_BACKOFF_BASE_SEC=30

FX_RATE_USD=1
FX_RATE_PHP=56
FX_RATE_EUR=0.92
FX_RATE_GBP=0.79
FX_RATE_JPY=150
FX_RATE_AUD=1.53
FX_RATE_CAD=1.36
